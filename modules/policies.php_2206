    try {
        $p = getDb()->prepare('SELECT * FROM policies WHERE id = ?');
        $p->execute([$pid]);
        $policy = $p->fetch(PDO::FETCH_ASSOC);
        if (!$policy) { echo '<div class="alert alert-error">Not found.</div>'; return; }
        $vs = getDb()->prepare(
            'SELECT id, version_label, effective_date, published_at, superseded_at, grace_days, is_major_update,
                    allow_download,
                    pdf_original_name, pdf_size_bytes,
                    (SELECT COUNT(*) FROM policy_consents c WHERE c.policy_version_id = policy_versions.id) AS consent_count
             FROM policy_versions
             WHERE policy_id = ? ORDER BY published_at DESC'
