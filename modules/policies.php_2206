// Manager / HR consent dashboard.
function pagePolicyConsentDashboard(): void {
    if (!policyCanViewDashboard()) { echo '<div class="alert alert-error">Access denied.</div>'; return; }

    // Filters
    $fPolicy = (int)($_GET['policy_id']    ?? 0);
    $fStaff  = $_GET['staff_type'] ?? '';
    $fDept   = (int)($_GET['department_id'] ?? 0);
    $fLoc    = (int)($_GET['location_id']   ?? 0);
    $fStatus = $_GET['status'] ?? '';   // '' | 'accepted' | 'pending'
    $viewClicked = !empty($_GET['view']);

    try {
        $policies = getDb()->query(
            "SELECT p.id, p.title, p.category,
                    (SELECT id FROM policy_versions v WHERE v.policy_id = p.id AND v.superseded_at IS NULL
                     ORDER BY v.published_at DESC LIMIT 1) AS current_version_id
             FROM   policies p
             WHERE  p.is_active = 1
             ORDER  BY p.title"
        )->fetchAll(PDO::FETCH_ASSOC);
    } catch (Exception $e) { $policies = []; }
    $depts = getDepartments();
    $locs  = getActiveLocations();

    $rows = [];
    if ($viewClicked && $fPolicy > 0) {
        $cur = null;
        foreach ($policies as $p) if ((int)$p['id'] === $fPolicy) { $cur = $p; break; }
        if ($cur && $cur['current_version_id']) {
            $vid = (int)$cur['current_version_id'];
            $allowedTypes = policyStaffTypesForCategory($cur['category']);
            $aud = policyAudienceForVersion($vid);
            $sql = 'SELECT e.employee_code, e.full_name, e.staff_type, e.department_id, e.location_id,
                           d.department_name, l.location_name,
                           c.consented_at
                    FROM   employees e
                    LEFT JOIN departments d ON d.id = e.department_id
                    LEFT JOIN locations  l ON l.location_id = e.location_id
                    LEFT JOIN policy_consents c ON c.policy_version_id = ? AND c.employee_code = e.employee_code
                    WHERE  e.is_active = 1';
            $params = [$vid];
            $typesForFilter = $fStaff && in_array($fStaff, $allowedTypes, true) ? [$fStaff] : $allowedTypes;
            $sql .= ' AND e.staff_type IN (' . implode(',', array_fill(0, count($typesForFilter), '?')) . ')';
            $params = array_merge($params, $typesForFilter);
            if (!empty($aud['departments'])) {
                $sql .= ' AND e.department_id IN (' . implode(',', array_fill(0, count($aud['departments']), '?')) . ')';
                $params = array_merge($params, $aud['departments']);
            }
            if (!empty($aud['locations'])) {
                $sql .= ' AND e.location_id IN (' . implode(',', array_fill(0, count($aud['locations']), '?')) . ')';
                $params = array_merge($params, $aud['locations']);
            }
            if ($fDept > 0)  { $sql .= ' AND e.department_id = ?'; $params[] = $fDept; }
            if ($fLoc  > 0)  { $sql .= ' AND e.location_id = ?';   $params[] = $fLoc; }
            if ($fStatus === 'accepted') $sql .= ' AND c.consented_at IS NOT NULL';
            if ($fStatus === 'pending')  $sql .= ' AND c.consented_at IS NULL';
            $sql .= ' ORDER BY e.full_name';
            try {
                $st = getDb()->prepare($sql);
                $st->execute($params);
                $rows = $st->fetchAll(PDO::FETCH_ASSOC);
            } catch (Exception $e) { $rows = []; }
        }
    }
?>
