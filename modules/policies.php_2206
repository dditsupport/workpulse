                <option value="retail"  <?= $fStaff==='retail'?'selected':'' ?>>Retail</option>
                <option value="ho"      <?= $fStaff==='ho'?'selected':'' ?>>HO</option>
                <option value="factory" <?= $fStaff==='factory'?'selected':'' ?>>Factory</option>
            </select>
        </div>
        <div class="form-group">
            <label>Department</label>
            <select name="department_id" class="form-control">
                <option value="0">All</option>
                <?php foreach ($depts as $d): ?>
                <option value="<?= (int)$d['id'] ?>" <?= $fDept === (int)$d['id'] ? 'selected' : '' ?>>
                    <?= h($d['department_name']) ?>
                </option>
                <?php endforeach; ?>
            </select>
        </div>
        <div class="form-group">
            <label>Location</label>
            <select name="location_id" class="form-control">
                <option value="0">All</option>
                <?php foreach ($locs as $l): ?>
                <option value="<?= (int)$l['location_id'] ?>" <?= $fLoc === (int)$l['location_id'] ? 'selected' : '' ?>>
                    <?= h($l['location_name']) ?>
                </option>
                <?php endforeach; ?>
            </select>
        </div>
        <div class="form-group">
            <label>Status</label>
            <select name="status" class="form-control">
                <option value="">All</option>
                <option value="accepted" <?= $fStatus==='accepted'?'selected':'' ?>>Accepted</option>
                <option value="pending"  <?= $fStatus==='pending'?'selected':'' ?>>Pending</option>
            </select>
        </div>
    </div>
    <div class="form-actions">
        <button class="btn btn-primary">View</button>
        <a href="?page=policy_consent_dashboard" class="btn btn-ghost">Reset</a>
    </div>
</form>

<?php if (!$viewClicked || $fPolicy < 1): ?>
<div class="rpt-prompt">Pick a policy and click <strong>View</strong>.</div>
<?php else:
    $accepted = 0; $pending = 0;
    foreach ($rows as $r) { if (!empty($r['consented_at'])) $accepted++; else $pending++; }
?>
<div class="text-muted" style="margin-bottom:8px">
    Showing <strong><?= count($rows) ?></strong> applicable employees —
    <span style="color:var(--green)"><?= $accepted ?> accepted</span>,
    <span style="color:var(--yellow)"><?= $pending ?> pending</span>.
</div>
<div class="table-wrap" data-stack>
    <table class="table">
        <thead>
            <tr>
                <th>Employee</th>
                <th style="width:80px">Type</th>
                <th>Department</th>
                <th>Location</th>
                <th style="width:160px">Status</th>
            </tr>
        </thead>
        <tbody>
        <?php if (empty($rows)): ?>
            <tr><td colspan="5" class="empty-row">No employees match the filter.</td></tr>
        <?php else: foreach ($rows as $r): ?>
            <tr>
                <td><strong><?= h($r['full_name']) ?></strong> <span class="text-muted">(<?= h($r['employee_code']) ?>)</span></td>
                <td><span class="badge badge-grey"><?= h(mb_strtoupper($r['staff_type'])) ?></span></td>
                <td><?= h($r['department_name'] ?? '—') ?></td>
                <td><?= h($r['location_name']   ?? '—') ?></td>
                <td>
                    <?php if (!empty($r['consented_at'])): ?>
                        <span class="badge badge-green">Accepted</span>
                        <span class="text-muted" style="font-size:11px"> · <?= h(date('d M Y', strtotime($r['consented_at']))) ?></span>
                    <?php else: ?>
                        <span class="badge badge-yellow">Pending</span>
                    <?php endif; ?>
                </td>
            </tr>
        <?php endforeach; endif; ?>
        </tbody>
    </table>
</div>
<?php endif; ?>
<?php
}

// Drill-down used by the violation module: full consent history for one employee.
function pagePolicyConsentHistory(): void {
    $empCode = trim($_GET['emp'] ?? '');
    if ($empCode === '' || (!policyCanViewDashboard() && myCode() !== $empCode)) {
        echo '<div class="alert alert-error">Access denied.</div>'; return;
    }
    try {
        $emp = getDb()->prepare('SELECT employee_code, full_name FROM employees WHERE employee_code = ?');
        $emp->execute([$empCode]);
        $eRow = $emp->fetch(PDO::FETCH_ASSOC);
        if (!$eRow) { echo '<div class="alert alert-error">Employee not found.</div>'; return; }

        $st = getDb()->prepare(
            "SELECT p.title, p.category, v.version_label, v.effective_date, v.published_at,
                    c.consented_at, c.ip_address, c.user_agent, c.pdf_sha256_at_consent
             FROM   policy_consents c
             JOIN   policy_versions v ON v.id = c.policy_version_id
             JOIN   policies p ON p.id = v.policy_id
             WHERE  c.employee_code = ?
             ORDER  BY c.consented_at DESC"
        );
        $st->execute([$empCode]);
        $rows = $st->fetchAll(PDO::FETCH_ASSOC);
    } catch (Exception $e) { $rows = []; }
?>
<div class="page-header" style="display:flex;align-items:center;gap:10px">
    <a href="javascript:history.back()" class="btn btn-sm btn-ghost">← Back</a>
    <h2 style="margin:0">Consent History — <?= h($eRow['full_name']) ?> <span class="text-muted">(<?= h($empCode) ?>)</span></h2>
</div>

<?php if (empty($rows)): ?>
<div class="rpt-prompt">No policy acceptances on record for this employee.</div>
<?php else: ?>
<div class="table-wrap" data-stack>
    <table class="table">
        <thead>
            <tr>
                <th>Policy</th>
                <th style="width:90px">Category</th>
                <th style="width:110px">Version</th>
                <th style="width:140px">Accepted</th>
                <th>IP / Device</th>
                <th style="width:100px">PDF SHA-256</th>
            </tr>
        </thead>
        <tbody>
        <?php foreach ($rows as $r):
            $catLabel = ['hr'=>'HR','it'=>'IT','store_management'=>'Store Mgmt'][$r['category']] ?? $r['category'];
        ?>
            <tr>
                <td><strong><?= h($r['title']) ?></strong></td>
                <td><span class="badge badge-grey"><?= h($catLabel) ?></span></td>
                <td><code><?= h($r['version_label']) ?></code></td>
                <td><?= h(date('d M Y H:i', strtotime($r['consented_at']))) ?></td>
                <td><span class="text-muted" style="font-size:11px"><?= h($r['ip_address'] ?? '—') ?><br><?= h(mb_substr($r['user_agent'] ?? '', 0, 80)) ?></span></td>
                <td><code style="font-size:10px"><?= h(mb_substr($r['pdf_sha256_at_consent'], 0, 12)) ?>…</code></td>
            </tr>
        <?php endforeach; ?>
        </tbody>
    </table>
</div>
<?php endif; ?>
<?php
}

// ── POST handlers ────────────────────────────────────────

function doPublishPolicyVersion(): void {
    if (!policyCanAdmin()) { flash('error', 'Access denied.'); header('Location: index.php?page=policies'); exit; }

    $title         = trim($_POST['title']         ?? '');
    $category      = $_POST['category']           ?? '';
    $versionLabel  = trim($_POST['version_label'] ?? '');
    $effective     = trim($_POST['effective_date']?? '');
    $graceDays     = max(0, min(60, (int)($_POST['grace_days'] ?? POLICY_DEFAULT_GRACE)));
    $isMajor       = !empty($_POST['is_major_update']) ? 1 : 0;
    $allowDownload = !empty($_POST['allow_download']) ? 1 : 0;
    $whatChanged   = trim($_POST['what_changed']  ?? '');
    $deptIds       = array_map('intval', (array)($_POST['department_ids'] ?? []));
    $locIds        = array_map('intval', (array)($_POST['location_ids']   ?? []));

    if ($title === '' || !in_array($category, ['hr','it','store_management'], true)
        || $versionLabel === '' || !preg_match('/^\d{4}-\d{2}-\d{2}$/', $effective)) {
        flash('error', 'Title, category, version label and effective date are required.');
        header('Location: index.php?page=policy_publish'); exit;
    }
    if (empty($_FILES['pdf']) || !is_uploaded_file($_FILES['pdf']['tmp_name'] ?? '')) {
        flash('error', 'PDF upload required.');
        header('Location: index.php?page=policy_publish'); exit;
    }
    if ($_FILES['pdf']['size'] > POLICY_MAX_BYTES) {
        flash('error', 'PDF exceeds maximum size.');
        header('Location: index.php?page=policy_publish'); exit;
    }
    $finfo = new finfo(FILEINFO_MIME_TYPE);
    $mime  = $finfo->file($_FILES['pdf']['tmp_name']);
    if ($mime !== 'application/pdf') {
        flash('error', 'File must be a PDF (got ' . h($mime) . ').');
        header('Location: index.php?page=policy_publish'); exit;
    }

    $db = getDb();
    try {
        $db->beginTransaction();

        // Find or create the policies row keyed on (title, category) — same
        // policy gets new versions across time. Simple-enough for v1.
        $find = $db->prepare('SELECT id FROM policies WHERE title = ? AND category = ? LIMIT 1');
        $find->execute([$title, $category]);
        $policyId = $find->fetchColumn();
        if (!$policyId) {
            $db->prepare('INSERT INTO policies (title, category, is_active, created_by) VALUES (?,?,1,?)')
               ->execute([$title, $category, myCode()]);
            $policyId = (int)$db->lastInsertId();
        } else {
            $policyId = (int)$policyId;
            // Mark previous versions as superseded (the new one supersedes all earlier active ones).
            $db->prepare('UPDATE policy_versions SET superseded_at = NOW() WHERE policy_id = ? AND superseded_at IS NULL')
               ->execute([$policyId]);
        }

        // Move the file into bucketed storage.
        $sha256       = hash_file('sha256', $_FILES['pdf']['tmp_name']);
        $size         = (int)$_FILES['pdf']['size'];
        $original     = preg_replace('/[^A-Za-z0-9._\- ]/', '_', $_FILES['pdf']['name']);
        $stored       = 'pol_' . uniqid('', true) . '.pdf';
        $bucket       = policyMonthBucket(date('Y-m-d H:i:s'));
        $bucketDir    = POLICY_UPLOAD_DIR . $bucket . '/';
        if (!is_dir($bucketDir) && !mkdir($bucketDir, 0775, true) && !is_dir($bucketDir)) {
            throw new Exception('Failed to create upload bucket dir.');
        }
        $destPath = $bucketDir . $stored;
        if (!move_uploaded_file($_FILES['pdf']['tmp_name'], $destPath)) {
            throw new Exception('Failed to save uploaded file.');
        }

        // Insert the version row.
        $db->prepare(
            'INSERT INTO policy_versions
                (policy_id, version_label, effective_date,
                 pdf_original_name, pdf_stored_name, pdf_sha256, pdf_size_bytes,
                 is_major_update, allow_download, what_changed, grace_days, published_by)
             VALUES (?,?,?,?,?,?,?,?,?,?,?,?)'
        )->execute([
            $policyId, $versionLabel, $effective,
            $original, $stored, $sha256, $size,
            $isMajor, $allowDownload,
            $whatChanged !== '' ? $whatChanged : null,
            $graceDays, myCode(),
        ]);
        $versionId = (int)$db->lastInsertId();

        // Audience filter rows
        $audSt = $db->prepare(
            'INSERT INTO policy_audience (policy_version_id, department_id, location_id) VALUES (?,?,?)'
        );
        foreach ($deptIds as $d) if ($d > 0) $audSt->execute([$versionId, $d, null]);
        foreach ($locIds  as $l) if ($l > 0) $audSt->execute([$versionId, null, $l]);

        $db->commit();
        flash('success', 'Policy published — ' . count($deptIds) . ' dept filter(s), ' . count($locIds) . ' location filter(s).');
        header('Location: index.php?page=policy_admin_versions&id=' . $policyId); exit;
    } catch (Exception $e) {
        if ($db->inTransaction()) $db->rollBack();
        flash('error', 'Publish failed: ' . $e->getMessage());
        header('Location: index.php?page=policy_publish'); exit;
    }
}

// Flip the allow_download bit on a specific version. Policy admin only.
function doTogglePolicyDownload(): void {
    if (!policyCanAdmin()) {
        flash('error', 'Access denied.');
        header('Location: index.php?page=policy_admin_list'); exit;
    }
    $vid = (int)($_POST['version_id'] ?? 0);
    if ($vid < 1) {
        flash('error', 'Invalid version.');
        header('Location: index.php?page=policy_admin_list'); exit;
    }
    try {
        getDb()->prepare('UPDATE policy_versions SET allow_download = 1 - allow_download WHERE id = ?')
            ->execute([$vid]);

        // Redirect back to the same versions page.
        $pidSt = getDb()->prepare('SELECT policy_id FROM policy_versions WHERE id = ?');
        $pidSt->execute([$vid]);
        $pid = (int)$pidSt->fetchColumn();
        flash('success', 'Download permission updated.');
        header('Location: index.php?page=policy_admin_versions&id=' . $pid); exit;
    } catch (Exception $e) {
        flash('error', 'Update failed: ' . $e->getMessage());
        header('Location: index.php?page=policy_admin_list'); exit;
    }
}

function doConsentPolicy(): void {
    $empCode = myCode();
    if ($empCode === '') { flash('error', 'Not logged in.'); header('Location: index.php?page=policies'); exit; }
    $vid = (int)($_POST['policy_version_id'] ?? 0);
    if ($vid < 1) { flash('error', 'Invalid policy.'); header('Location: index.php?page=policies'); exit; }

    // Server-side gate: scroll-progress + view-time, both anchored in $_SESSION.
    $gate = policyViewGateOk($vid);
    if (!$gate['ok']) {
        flash('error', $gate['error']);
        header('Location: index.php?page=policy_view&id=' . $vid); exit;
    }

    // OTP gate — must have a live OTP for this exact vid in session.
    $otpInput = preg_replace('/\D+/', '', (string)($_POST['otp'] ?? ''));
    if (!isset($_SESSION['policy_otp']) || (int)($_SESSION['policy_otp_vid'] ?? 0) !== $vid) {
        flash('error', 'Request an OTP first, then enter it to accept.');
        header('Location: index.php?page=policy_view&id=' . $vid); exit;
    }
    if (time() > (int)($_SESSION['policy_otp_expires'] ?? 0)) {
        unset($_SESSION['policy_otp'], $_SESSION['policy_otp_vid'], $_SESSION['policy_otp_phone'],
              $_SESSION['policy_otp_phone_mask'], $_SESSION['policy_otp_expires'],
              $_SESSION['policy_otp_last_sent'], $_SESSION['policy_otp_attempts']);
        flash('error', 'OTP expired. Please request a new one.');
        header('Location: index.php?page=policy_view&id=' . $vid); exit;
    }
    if ((int)($_SESSION['policy_otp_attempts'] ?? 0) >= POLICY_OTP_MAX_ATTEMPTS) {
        unset($_SESSION['policy_otp'], $_SESSION['policy_otp_vid'], $_SESSION['policy_otp_phone'],
              $_SESSION['policy_otp_phone_mask'], $_SESSION['policy_otp_expires'],
              $_SESSION['policy_otp_last_sent'], $_SESSION['policy_otp_attempts']);
        flash('error', 'Too many wrong attempts. Please request a new OTP.');
        header('Location: index.php?page=policy_view&id=' . $vid); exit;
    }
    if ($otpInput === '' || !hash_equals((string)$_SESSION['policy_otp'], $otpInput)) {
        $_SESSION['policy_otp_attempts'] = (int)($_SESSION['policy_otp_attempts'] ?? 0) + 1;
        $left = POLICY_OTP_MAX_ATTEMPTS - (int)$_SESSION['policy_otp_attempts'];
        flash('error', 'Invalid OTP.' . ($left > 0 ? " You have $left attempt(s) left." : ' Please request a new one.'));
        header('Location: index.php?page=policy_view&id=' . $vid); exit;
    }

    try {
        $st = getDb()->prepare('SELECT * FROM policy_versions WHERE id = ?');
        $st->execute([$vid]);
        $v = $st->fetch(PDO::FETCH_ASSOC);
        if (!$v) { flash('error', 'Policy not found.'); header('Location: index.php?page=policies'); exit; }

        // INSERT — UNIQUE KEY prevents duplicates (first one wins).
        $ip = $_SERVER['REMOTE_ADDR']      ?? null;
        $ua = $_SERVER['HTTP_USER_AGENT']  ?? null;
        try {
            getDb()->prepare(
                'INSERT INTO policy_consents
                    (policy_version_id, employee_code, pdf_sha256_at_consent, ip_address, user_agent)
                 VALUES (?,?,?,?,?)'
            )->execute([$vid, $empCode, $v['pdf_sha256'], $ip, $ua ? mb_substr($ua, 0, 500) : null]);
        } catch (PDOException $e) {
            // Duplicate-key — already accepted. Treat as success.
            if ((int)$e->errorInfo[1] !== 1062) throw $e;
        }
        unset($_SESSION['policy_view_start'], $_SESSION['policy_view_start_id'],
              $_SESSION['policy_view_max_page'], $_SESSION['policy_view_total'],
              $_SESSION['policy_otp'], $_SESSION['policy_otp_vid'], $_SESSION['policy_otp_phone'],
              $_SESSION['policy_otp_phone_mask'], $_SESSION['policy_otp_expires'],
              $_SESSION['policy_otp_last_sent'], $_SESSION['policy_otp_attempts']);
        flash('success', 'Policy accepted. Thank you.');
        header('Location: index.php?page=policies'); exit;
    } catch (Exception $e) {
        flash('error', 'Consent failed: ' . $e->getMessage());
        header('Location: index.php?page=policy_view&id=' . $vid); exit;
    }
}

// ── Policy OTP handlers ───────────────────────────────────
function doRequestPolicyOtp(): void {
    $empCode = myCode();
    if ($empCode === '') { flash('error', 'Not logged in.'); header('Location: index.php?page=policies'); exit; }
    $vid = (int)($_POST['policy_version_id'] ?? 0);
    if ($vid < 1) { flash('error', 'Invalid policy.'); header('Location: index.php?page=policies'); exit; }

    // Same scroll/time gate as the final accept — can't shortcut by requesting OTP early.
    $gate = policyViewGateOk($vid);
    if (!$gate['ok']) {
        flash('error', $gate['error']);
        header('Location: index.php?page=policy_view&id=' . $vid); exit;
    }

    // Resend cooldown — only if this OTP request is for the same vid as a live in-flight OTP.
    if ((int)($_SESSION['policy_otp_vid'] ?? 0) === $vid && !empty($_SESSION['policy_otp_last_sent'])) {
        $waitedFor = time() - (int)$_SESSION['policy_otp_last_sent'];
        if ($waitedFor < POLICY_OTP_RESEND_SECS) {
            $left = POLICY_OTP_RESEND_SECS - $waitedFor;
            flash('error', "Please wait {$left}s before requesting another OTP.");
            header('Location: index.php?page=policy_view&id=' . $vid); exit;
        }
    }

    // Get employee phone
    try {
        $st = getDb()->prepare('SELECT phone, full_name FROM employees WHERE employee_code = ? AND is_active = 1 LIMIT 1');
        $st->execute([$empCode]);
        $emp = $st->fetch(PDO::FETCH_ASSOC);
    } catch (Exception $e) {
        flash('error', 'Database error: ' . $e->getMessage());
        header('Location: index.php?page=policy_view&id=' . $vid); exit;
    }
    if (!$emp) { flash('error', 'Employee record not found.'); header('Location: index.php?page=policy_view&id=' . $vid); exit; }

    $phone = preg_replace('/\D+/', '', (string)($emp['phone'] ?? ''));
    if (strlen($phone) < 10) {
        flash('error', 'No mobile number on file. Ask HR to update your mobile in your employee profile before accepting policies.');
        header('Location: index.php?page=policy_view&id=' . $vid); exit;
    }
    // Normalise to 10-digit (drop +91 / 91 prefix if present).
    if (strlen($phone) > 10 && substr($phone, 0, 2) === '91') $phone = substr($phone, -10);

    // Resend keeps the SAME code: if a live OTP already exists for this policy
    // version, re-send it instead of generating a new one (and don't reset its
    // expiry or attempt counter). Only mint a fresh OTP for a first request or
    // once the previous one has expired.
    $liveResend = (int)($_SESSION['policy_otp_vid'] ?? 0) === $vid
        && !empty($_SESSION['policy_otp'])
        && (int)($_SESSION['policy_otp_expires'] ?? 0) > time();
    $otp = $liveResend
        ? (string)$_SESSION['policy_otp']
        : str_pad((string)random_int(0, 999999), 6, '0', STR_PAD_LEFT);
    $_SESSION['policy_otp']            = $otp;
    $_SESSION['policy_otp_vid']        = $vid;
    $_SESSION['policy_otp_phone']      = $phone;
    $_SESSION['policy_otp_phone_mask'] = policyMaskPhone($phone);
    if (!$liveResend) {
        $_SESSION['policy_otp_expires']  = time() + POLICY_OTP_TTL_SECS;
        $_SESSION['policy_otp_attempts'] = 0;
    }
    $_SESSION['policy_otp_last_sent']  = time();

    // Prefer MSG91 v5 Flow when a flow template_id is configured (faster, more
    // reliable delivery). The flow's variable must be named ##OTP##. Falls back
    // to the legacy templated send() when no flow id is set, so nothing breaks
    // before the flow is configured in Settings.
    $flowId = getSetting('sms_policy_otp_flow_id', '');
    if ($flowId !== '') {
        $resp = SmsService::sendFlow($flowId, '91' . $phone, ['OTP' => $otp]);
    } else {
        // Substitute {OTP} into the configured template. If unset, fall back to
        // the wording the DLT submission was approved for so the SMS still
        // passes the operator's regex check.
        $template = getSetting(
            'sms_policy_otp_template',
            'Your OTP is {OTP}. Valid for 10 minutes. By using this OTP, you agree to DD Internal Employee policies. Don\'t share with anyone. Dangee Dums Ltd'
        );
        $message  = str_replace('{OTP}', $otp, $template);
        $dltId    = getSetting('sms_policy_otp_dlt_id', '1707177847730015071');
        $resp     = SmsService::send('91' . $phone, $message, $dltId);
    }
    // MSG91 returns a request-id on success; treat curl errors / empty as failure.
    if ($resp === '' || stripos($resp, 'error') !== false) {
        // Clear partial state so the user can retry without hitting the cooldown.
        unset($_SESSION['policy_otp'], $_SESSION['policy_otp_vid'], $_SESSION['policy_otp_phone'],
              $_SESSION['policy_otp_phone_mask'], $_SESSION['policy_otp_expires'],
              $_SESSION['policy_otp_last_sent'], $_SESSION['policy_otp_attempts']);
        flash('error', 'Failed to send OTP. Please try again or contact HR.');
        header('Location: index.php?page=policy_view&id=' . $vid); exit;
    }

    flash('success', 'OTP sent to ' . $_SESSION['policy_otp_phone_mask'] . '. Enter it below to accept the policy.');
    header('Location: index.php?page=policy_view&id=' . $vid); exit;
}

function doCancelPolicyOtp(): void {
    $vid = (int)($_POST['policy_version_id'] ?? 0);
    unset($_SESSION['policy_otp'], $_SESSION['policy_otp_vid'], $_SESSION['policy_otp_phone'],
          $_SESSION['policy_otp_phone_mask'], $_SESSION['policy_otp_expires'],
          $_SESSION['policy_otp_last_sent'], $_SESSION['policy_otp_attempts']);
    flash('success', 'OTP request cancelled.');
    if ($vid > 0) { header('Location: index.php?page=policy_view&id=' . $vid); }
    else          { header('Location: index.php?page=policies'); }
    exit;
}
