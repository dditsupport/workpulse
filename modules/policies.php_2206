// PDF.js viewer + consent buttons.
function pagePolicyView(): void {
    $empCode = myCode();
    if ($empCode === '') { echo '<div class="alert alert-error">Not logged in.</div>'; return; }
    $vid = (int)($_GET['id'] ?? 0);
    if ($vid < 1) { echo '<div class="alert alert-error">Invalid policy.</div>'; return; }

    try {
        $st = getDb()->prepare(
            'SELECT v.*, p.title, p.category, p.is_active AS policy_active
             FROM   policy_versions v
             JOIN   policies p ON p.id = v.policy_id
             WHERE  v.id = ?'
        );
        $st->execute([$vid]);
        $v = $st->fetch(PDO::FETCH_ASSOC);
    } catch (Exception $e) { echo '<div class="alert alert-error">DB: ' . h($e->getMessage()) . '</div>'; return; }

    if (!$v) { echo '<div class="alert alert-error">Policy not found.</div>'; return; }

    // Scope check (admins always pass)
    if (!policyCanAdmin()) {
        $emp = getDb()->prepare('SELECT department_id, location_id, staff_type FROM employees WHERE employee_code = ? AND is_active = 1');
        $emp->execute([$empCode]);
        $eRow = $emp->fetch(PDO::FETCH_ASSOC);
        if (!$eRow || !policyEmployeeInScope($eRow, $v)) {
            echo '<div class="alert alert-error">This policy does not apply to you.</div>'; return;
        }
    }

    $consentSt = getDb()->prepare('SELECT consented_at FROM policy_consents WHERE policy_version_id = ? AND employee_code = ? LIMIT 1');
    $consentSt->execute([$vid, $empCode]);
    $consented = (bool)$consentSt->fetch(PDO::FETCH_ASSOC);

    $deadline    = strtotime($v['published_at']) + ((int)$v['grace_days'] * 86400);
    $pastGrace   = time() > $deadline;
    $catLabel    = ['hr'=>'HR','it'=>'IT','store_management'=>'Store Management'][$v['category']] ?? $v['category'];

    // Initialise (or refresh) the consent-tracking session entry.
    // We anchor view-time to the SERVER's clock — the client can't fake it.
    if (!isset($_SESSION['policy_view_start']) || ($_SESSION['policy_view_start_id'] ?? 0) !== $vid) {
        $_SESSION['policy_view_start']     = time();
        $_SESSION['policy_view_start_id']  = $vid;
        $_SESSION['policy_view_max_page']  = 0;
        $_SESSION['policy_view_total']     = 0;
    }

    $pdfUrl = '?page=policy_pdf&id=' . $vid;
?>
<div class="page-header" style="display:flex;align-items:center;gap:10px;flex-wrap:wrap">
    <a href="?page=policies" class="btn btn-sm btn-ghost">← Back</a>
    <h2 style="margin:0"><?= h($v['title']) ?></h2>
    <span class="badge badge-grey"><?= h($catLabel) ?></span>
    <span class="badge badge-blue"><?= h($v['version_label']) ?></span>
    <?php if (!empty($v['is_major_update'])): ?><span class="badge badge-yellow">MAJOR UPDATE</span><?php endif; ?>
    <?php if (!empty($v['allow_download']) || policyCanAdmin()): ?>
    <a href="?page=policy_pdf&id=<?= (int)$vid ?>&download=1"
       class="btn btn-sm btn-ghost"
       style="margin-left:auto"
       title="Download a local copy of this PDF">
        ⬇ Download PDF
    </a>
    <?php endif; ?>
    <?php if ($consented): ?><span class="badge badge-green" style="<?= (!empty($v['allow_download']) || policyCanAdmin()) ? '' : 'margin-left:auto' ?>">Already accepted</span><?php endif; ?>
</div>

<?php if (!empty($v['what_changed'])): ?>
<div class="form-card" style="max-width:none;margin-bottom:14px;border-left:3px solid var(--accent)">
    <div class="form-section-title" style="margin-top:0">What changed</div>
    <p style="margin:0;font-size:13px;line-height:1.5"><?= h($v['what_changed']) ?></p>
</div>
<?php endif; ?>

<div class="form-card" style="max-width:none;padding:0;overflow:hidden">
    <div id="pdfStatus" style="padding:10px 14px;border-bottom:1px solid var(--border);font-size:12px;color:var(--muted);display:flex;align-items:center;gap:12px;flex-wrap:wrap">
        <span id="pdfStatusText">Loading PDF…</span>
        <span style="margin-left:auto" id="pdfPageInfo"></span>
    </div>
    <div id="pdfContainer" style="max-height:75vh;overflow-y:auto;background:#1a1a1a;padding:14px">
        <!-- canvases injected here, one per page -->
    </div>
</div>

<?php
$pendingOtp = !$consented
              && isset($_SESSION['policy_otp'])
              && (int)($_SESSION['policy_otp_vid'] ?? 0) === $vid
              && time() <= (int)($_SESSION['policy_otp_expires'] ?? 0)
              && (int)($_SESSION['policy_otp_attempts'] ?? 0) < POLICY_OTP_MAX_ATTEMPTS;
$otpAttemptsLeft = $pendingOtp ? max(0, POLICY_OTP_MAX_ATTEMPTS - (int)($_SESSION['policy_otp_attempts'] ?? 0)) : 0;
?>

<?php if ($consented): ?>
<div style="margin-top:14px;display:flex;gap:10px;align-items:center;flex-wrap:wrap">
    <span class="text-muted" style="font-size:13px">You accepted this version on <?= h(date('d M Y H:i', strtotime($v['consented_at'] ?? 'now'))) ?>.</span>
</div>
<?php elseif ($pendingOtp): ?>
<div class="form-card" style="max-width:none;margin-top:14px;padding:14px">
    <div class="form-section-title" style="margin-top:0">Enter OTP to accept</div>
    <p style="margin:0 0 10px;font-size:13px">
        OTP sent to <strong><?= h($_SESSION['policy_otp_phone_mask'] ?? '') ?></strong>
        — valid for <span id="otpCountdown">--:--</span>
        <?php if ($otpAttemptsLeft < POLICY_OTP_MAX_ATTEMPTS): ?>
            · <?= (int)$otpAttemptsLeft ?> attempt(s) left
        <?php endif; ?>
    </p>
    <form method="POST" data-no-disable style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
        <input type="hidden" name="action"            value="consent_policy">
        <input type="hidden" name="policy_version_id" value="<?= $vid ?>">
        <input type="text" name="otp" inputmode="numeric" pattern="[0-9]{6}" maxlength="6"
               class="form-control"
               style="max-width:160px;letter-spacing:6px;text-align:center;font-size:18px"
               placeholder="6-digit OTP" autocomplete="one-time-code" required autofocus>
        <button type="submit" class="btn btn-success">Verify &amp; Accept</button>
    </form>
    <form method="POST" data-no-disable style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;margin-top:10px">
        <input type="hidden" name="policy_version_id" value="<?= $vid ?>">
        <button type="submit" name="action" value="request_policy_otp"
                class="btn btn-ghost btn-sm" id="btnResendOtp">Resend OTP</button>
        <button type="submit" name="action" value="cancel_policy_otp"
                class="btn btn-ghost btn-sm">Cancel</button>
    </form>
</div>
<script>
(function () {
    var expiresAt     = <?= (int)$_SESSION['policy_otp_expires'] ?> * 1000;
    var resendReadyAt = <?= ((int)($_SESSION['policy_otp_last_sent'] ?? 0) + POLICY_OTP_RESEND_SECS) ?> * 1000;
    var cd        = document.getElementById('otpCountdown');
    var btnResend = document.getElementById('btnResendOtp');
    var reloaded  = false;
    function tick() {
        var now  = Date.now();
        var left = Math.max(0, Math.floor((expiresAt - now) / 1000));
        if (cd) {
            var m = Math.floor(left / 60), s = left % 60;
            cd.textContent = m + ':' + (s < 10 ? '0' : '') + s;
        }
        var rLeft = Math.max(0, Math.floor((resendReadyAt - now) / 1000));
        if (btnResend) {
            if (rLeft > 0) {
                btnResend.disabled    = true;
                btnResend.textContent = 'Resend OTP (in ' + rLeft + 's)';
            } else {
                btnResend.disabled    = false;
                btnResend.textContent = 'Resend OTP';
            }
        }
        if (left <= 0 && !reloaded) { reloaded = true; location.reload(); }
    }
    tick();
    setInterval(tick, 1000);
})();
</script>
<?php else: ?>
<form method="POST" id="consentForm" data-no-disable style="margin-top:14px;display:flex;gap:10px;align-items:center;flex-wrap:wrap">
    <input type="hidden" name="action"            value="request_policy_otp">
