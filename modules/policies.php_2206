</form>
<?php endif; ?>

<script type="module">
// json_encode (not h()) — inside <script>, HTML entity decoding doesn't
// happen, so h() would smuggle "&amp;" into the URL and PHP's $_GET
// would split on the wrong delimiter.
const pdfMjsUrl    = <?= json_encode(policyPdfjsAssetUrl('pdf.mjs'),        JSON_UNESCAPED_SLASHES | JSON_HEX_TAG | JSON_HEX_AMP) ?>;
const pdfWorkerUrl = <?= json_encode(policyPdfjsAssetUrl('pdf.worker.mjs'), JSON_UNESCAPED_SLASHES | JSON_HEX_TAG | JSON_HEX_AMP) ?>;
const pdfStreamUrl = <?= json_encode($pdfUrl,                               JSON_UNESCAPED_SLASHES | JSON_HEX_TAG | JSON_HEX_AMP) ?>;
const container  = document.getElementById('pdfContainer');
const statusText = document.getElementById('pdfStatusText');
const pageInfo   = document.getElementById('pdfPageInfo');
const btnAccept  = document.getElementById('btnAccept');
let totalPages = 0, maxPageSeen = 0;
let viewSecs = 0;
const viewStart = Date.now();

function showError(html) {
    statusText.innerHTML = html;
    statusText.style.color = 'var(--red)';
}

(async () => {
    // Step 0 — Chrome ≤118 (notably Chrome 109, the last build for Windows
    // 7/8/8.1) lacks Promise.withResolvers (Chrome 119+) and the static
    // URL.parse (Chrome 126+), both of which PDF.js calls — without them it
    // throws "Promise.withResolvers is not a function" before rendering.
    // Define them inline here, BEFORE any import(), so the fix applies whether
    // PDF.js loads from lib/pdfjs/ OR the CDN fallback below. No-op on modern
    // browsers. (The worker has its own scope — it's polyfilled separately
    // where workerSrc is set.)
    if (typeof Promise.withResolvers !== 'function') {
        Promise.withResolvers = function () {
            let resolve, reject;
            const promise = new Promise((res, rej) => { resolve = res; reject = rej; });
            return { promise, resolve, reject };
        };
    }
    if (typeof URL.parse !== 'function') {
        URL.parse = function (url, base) {
            try { return (base === undefined || base === null) ? new URL(url) : new URL(url, base); }
            catch (e) { return null; }
        };
    }

    // Step 1 — load PDF.js. Prefer vendored files at lib/pdfjs/ (no
    // outbound network needed); fall back to a public CDN so the viewer
    // works out-of-the-box before the admin has dropped the files in.
    const CDN_VERSION  = '4.6.82';
    const cdnPdfMjs    = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/' + CDN_VERSION + '/pdf.min.mjs';
    const cdnWorkerMjs = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/' + CDN_VERSION + '/pdf.worker.min.mjs';
    let pdfjs, workerUrl;
    try {
        pdfjs = await import(pdfMjsUrl);
        workerUrl = pdfWorkerUrl;
    } catch (errLocal) {
        try {
            pdfjs = await import(cdnPdfMjs);
            workerUrl = cdnWorkerMjs;
            statusText.style.opacity = '.75';
            statusText.textContent = 'Using PDF.js from CDN — drop pdf.mjs + pdf.worker.mjs into lib/pdfjs/ to host locally.';
        } catch (errCdn) {
            showError(
                'PDF viewer library failed to load (local + CDN both failed).<br>' +
                'Local: <code>' + pdfMjsUrl + '</code><br>' +
                'CDN: <code>' + cdnPdfMjs + '</code><br>' +
                '<span style="opacity:.7">(' + (errCdn && errCdn.message ? errCdn.message : errCdn) + ')</span>'
            );
            return;
        }
    }
    // The worker has its own global scope, so the Step 0 polyfill doesn't reach
    // it. PDF.js spawns module workers, so point workerSrc at a same-origin Blob
    // that defines the same polyfills, then imports the real worker (local or
    // CDN). Mirrors PDF.js's own cross-origin blob wrapper; top-level await is
    // fine in a module worker (Chrome 89+).
    const workerAbsUrl = new URL(workerUrl, document.baseURI).href;
    const workerBootstrap =
        'if(typeof Promise.withResolvers!=="function"){Promise.withResolvers=function(){let r,j;const p=new Promise((a,b)=>{r=a;j=b;});return{promise:p,resolve:r,reject:j};};}' +
        'if(typeof URL.parse!=="function"){URL.parse=function(u,b){try{return (b===undefined||b===null)?new URL(u):new URL(u,b);}catch(e){return null;}};}' +
        'await import(' + JSON.stringify(workerAbsUrl) + ');';
    pdfjs.GlobalWorkerOptions.workerSrc = URL.createObjectURL(
        new Blob([workerBootstrap], { type: 'text/javascript' })
    );

    // Step 2 — sanity-check that the PDF stream URL actually returns a PDF
    // before handing it to PDF.js. This makes path/permission failures
    // distinguishable from PDF.js library failures.
    try {
        const head = await fetch(pdfStreamUrl, { method: 'HEAD' });
        if (!head.ok) {
            showError('PDF file not accessible (HTTP ' + head.status + '). The file may have been deleted from <code>uploads/policies/</code>, or your role doesn’t have permission to view this policy.');
            return;
        }
        const ct = head.headers.get('content-type') || '';
        if (!ct.includes('pdf')) {
            showError('Server returned <code>' + ct + '</code> instead of a PDF. Likely an auth redirect or PHP error — open <a href="' + pdfStreamUrl + '" target="_blank">' + pdfStreamUrl + '</a> directly to see the response.');
            return;
        }
    } catch (err) {
        showError('Could not reach the PDF stream: ' + (err && err.message ? err.message : err));
        return;
    }

    // Step 3 — render
    try {
        const pdf = await pdfjs.getDocument(pdfStreamUrl).promise;
        totalPages = pdf.numPages;
        statusText.textContent = 'Read all ' + totalPages + ' page' + (totalPages === 1 ? '' : 's') + ' to request the acceptance OTP.';
        const observer = new IntersectionObserver(entries => {
            entries.forEach(e => {
                if (e.isIntersecting) {
                    const n = parseInt(e.target.dataset.pageNum, 10);
                    if (n > maxPageSeen) maxPageSeen = n;
                    updateProgress();
                }
            });
        }, { root: container, threshold: 0.4 });

        for (let i = 1; i <= totalPages; i++) {
            const wrap = document.createElement('div');
            wrap.className = 'pdf-page-wrap';
            wrap.dataset.pageNum = i;
            wrap.style.cssText = 'margin:0 auto 14px;max-width:900px;background:#fff;box-shadow:0 2px 10px rgba(0,0,0,.5)';
            const canvas = document.createElement('canvas');
            canvas.style.cssText = 'display:block;width:100%;height:auto';
            wrap.appendChild(canvas);
            container.appendChild(wrap);
            observer.observe(wrap);

            const page = await pdf.getPage(i);
            const viewport = page.getViewport({ scale: 1.5 });
            canvas.width  = viewport.width;
            canvas.height = viewport.height;
            await page.render({ canvasContext: canvas.getContext('2d'), viewport }).promise;
        }
    } catch (err) {
        showError('Failed to render PDF: ' + (err && err.message ? err.message : err));
    }
})();

let lastReportedMax = -1, lastReportedTotal = -1;
function updateProgress() {
    pageInfo.textContent = 'Read ' + maxPageSeen + ' / ' + totalPages;
    decideAcceptEnabled();
    // Push to server immediately on any progress change so the server-side
    // gate doesn't fall behind the client. The 5s polling beat is a fallback.
    if (maxPageSeen !== lastReportedMax || totalPages !== lastReportedTotal) {
        lastReportedMax   = maxPageSeen;
        lastReportedTotal = totalPages;
        sendHeartbeat();
    }
}
function decideAcceptEnabled() {
    if (!btnAccept) return;
    viewSecs = Math.floor((Date.now() - viewStart) / 1000);
    const pagesOk = totalPages > 0 && maxPageSeen >= Math.max(1, Math.ceil(totalPages * 0.9));
    const minSecs = Math.min(<?= POLICY_VIEW_MAX_SECS ?>, Math.max(<?= POLICY_VIEW_MIN_SECS ?>, Math.ceil(totalPages * <?= POLICY_VIEW_PAGE_RATIO ?>)));
    const timeOk  = viewSecs >= minSecs;
    btnAccept.disabled = !(pagesOk && timeOk);
    btnAccept.title = pagesOk && timeOk
        ? 'You can now request the OTP to accept this policy'
        : 'Scroll through the document (' + maxPageSeen + '/' + totalPages + ') and stay for at least ' + minSecs + ' s';
}
setInterval(decideAcceptEnabled, 1000);

// Heartbeat — server uses this for its own validation. Sent as GET so it
// routes through index.php's special-page dispatcher (POST would land in
// routePost() with no action and silently exit).
function sendHeartbeat() {
    fetch('?page=policy_heartbeat&id=<?= $vid ?>&max_page=' + maxPageSeen + '&total=' + totalPages, { method: 'GET', cache: 'no-store' })
        .catch(() => {});
}
// updateProgress() already pushes a beat on each scroll event; this 5s
// interval is a fallback in case no scrolling has happened recently.
setInterval(sendHeartbeat, 5000);
</script>
<?php
}

// Heartbeat endpoint — POST only, updates session state. Safe to call
// repeatedly; never trusts the values blindly (they're capped + sanity-
// checked in doConsentPolicy()).
function pagePolicyHeartbeat(): void {
    $vid = (int)($_GET['id'] ?? 0);
    if ($vid < 1 || ($_SESSION['policy_view_start_id'] ?? 0) !== $vid) {
        http_response_code(400); echo '{"ok":false}'; return;
    }
    $maxPage = max(0, min(10000, (int)($_GET['max_page'] ?? 0)));
    $total   = max(0, min(10000, (int)($_GET['total']    ?? 0)));
    $_SESSION['policy_view_max_page'] = max((int)($_SESSION['policy_view_max_page'] ?? 0), $maxPage);
    $_SESSION['policy_view_total']    = $total;
    header('Content-Type: application/json');
    echo json_encode(['ok' => true, 'view_secs' => time() - (int)$_SESSION['policy_view_start']]);
}

// Stream the PDF file. Auth: must be in scope OR a policy admin OR superadmin.
function pagePolicyPdf(): void {
    if (!isLoggedIn()) { http_response_code(403); echo 'Forbidden'; return; }
    $empCode = myCode(); // empty string for the keyword 'superadmin' login
    $vid = (int)($_GET['id'] ?? 0);
    if ($vid < 1) { http_response_code(400); echo 'Bad request'; return; }
    try {
        $st = getDb()->prepare(
            'SELECT v.*, p.category, p.is_active AS policy_active
             FROM   policy_versions v JOIN policies p ON p.id = v.policy_id
             WHERE  v.id = ?'
        );
        $st->execute([$vid]);
        $v = $st->fetch(PDO::FETCH_ASSOC);
    } catch (Exception $e) { http_response_code(500); echo 'DB error'; return; }
    if (!$v) { http_response_code(404); echo 'Not found'; return; }

    if (!policyCanAdmin()) {
        $emp = getDb()->prepare('SELECT department_id, location_id, staff_type FROM employees WHERE employee_code = ? AND is_active = 1');
        $emp->execute([$empCode]);
        $eRow = $emp->fetch(PDO::FETCH_ASSOC);
        if (!$eRow || !policyEmployeeInScope($eRow, $v)) {
            http_response_code(403); echo 'Forbidden'; return;
        }
    }
    $path = policyAttachmentPath((string)$v['published_at'], (string)$v['pdf_stored_name'], false);
    if (!is_file($path)) { http_response_code(404); echo 'File missing'; return; }

    // Download branch: caller passed &download=1 expecting a saved file.
    // Employees need allow_download=1 on the version; admins always pass.
    $wantDownload = !empty($_GET['download']);
    if ($wantDownload && !policyCanAdmin() && empty($v['allow_download'])) {
        http_response_code(403); echo 'Download not permitted for this policy.'; return;
    }

    header('Content-Type: application/pdf');
    header('Content-Length: ' . filesize($path));
    header('Cache-Control: private, max-age=300');
    header('X-Content-Type-Options: nosniff');
    if ($wantDownload) {
        // Sanitise the original name the same way the upload handler did.
        $orig = preg_replace('/[^A-Za-z0-9._\- ]/', '_', (string)$v['pdf_original_name']);
        if ($orig === '' || $orig === null) $orig = 'policy.pdf';
        header('Content-Disposition: attachment; filename="' . $orig . '"');
    }
    readfile($path);
}

