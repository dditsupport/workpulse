<?php
// =========================================================
// Policies — publish + view + consent capture
// Phase 5 of the WorkPulse roadmap.
//
// Schema:    migrations/2026_05_08_phase5_policy_module.sql
// Storage:   uploads/policies/YYYY-MM/{stored}.pdf
// Frontend:  Mozilla PDF.js (drop pdf.mjs + pdf.worker.mjs into
//            lib/pdfjs/ — see policyPdfjsAssetUrl() below).
// =========================================================

require_once __DIR__ . '/SmsService.php';

// ── Constants ────────────────────────────────────────────
define('POLICY_UPLOAD_DIR',     __DIR__ . '/../uploads/policies/');
define('POLICY_MAX_BYTES',      15 * 1024 * 1024); // 15 MB cap per PDF
define('POLICY_DEFAULT_GRACE',  7);                // days
define('POLICY_VIEW_MIN_SECS',  0);                // no minimum reading-time delay
define('POLICY_VIEW_PAGE_RATIO',0);                // (time gate disabled — scroll-through still required)
define('POLICY_VIEW_MAX_SECS',  120);              // cap
define('POLICY_OTP_TTL_SECS',     600);             // 10 minutes — matches SMS template wording
define('POLICY_OTP_RESEND_SECS',  60);              // min seconds between sends
define('POLICY_OTP_MAX_ATTEMPTS', 5);               // wrong-OTP cap before forcing a new send

// ── Scroll/time gate (shared by OTP request + final consent) ──
// Returns ['ok' => bool, 'error' => string, 'min_secs' => int].
// Reads from the same $_SESSION['policy_view_*'] keys that the PDF
// viewer JS heartbeat populates (pagePolicyHeartbeat).
function policyViewGateOk(int $vid): array {
    if (($_SESSION['policy_view_start_id'] ?? 0) !== $vid) {
        return ['ok' => false, 'error' => 'Open the policy first, then accept.', 'min_secs' => 0];
    }
    $viewSecs = time() - (int)($_SESSION['policy_view_start'] ?? time());
    $maxPage  = (int)($_SESSION['policy_view_max_page'] ?? 0);
    $totalSes = (int)($_SESSION['policy_view_total']    ?? 0);
    $totalPages = max(1, $totalSes);
    $pagesOk    = $maxPage >= max(1, (int)ceil($totalPages * 0.9));
    $minSecs    = min(POLICY_VIEW_MAX_SECS, max(POLICY_VIEW_MIN_SECS, (int)ceil($totalPages * POLICY_VIEW_PAGE_RATIO)));
    $timeOk     = $viewSecs >= $minSecs;
    if (!$pagesOk || !$timeOk) {
        return ['ok' => false,
                'error' => 'Please scroll through the document and stay for at least ' . $minSecs . ' s before accepting.',
                'min_secs' => $minSecs];
    }
    return ['ok' => true, 'error' => '', 'min_secs' => $minSecs];
}

// Mask a phone number for UI display: "98••••1234".
function policyMaskPhone(string $phone): string {
    $digits = preg_replace('/\D+/', '', $phone) ?? '';
    if (strlen($digits) < 4) return str_repeat('•', max(0, strlen($digits)));
    $tail = substr($digits, -4);
    $head = strlen($digits) > 6 ? substr($digits, 0, 2) : '';
    return $head . str_repeat('•', max(2, strlen($digits) - strlen($head) - 4)) . $tail;
}

// ── Permission helpers ──────────────────────────────────
function policyCanAdmin(): bool {
    return isSuperadmin() || hasTxn('policy_admin');
}
// Who sees the consent dashboard. Policy admins always do (they're
// the publishers); anyone with the dedicated txn_policy_dashboard
// permission also does (assign to Operations / HR managers).
function policyCanViewDashboard(): bool {
    return policyCanAdmin() || hasTxn('policy_dashboard');
}

// ── Storage path resolver (mirrors pvAttachmentPath) ────
function policyMonthBucket(string $when): string {
    $ts = strtotime($when);
    return date('Y-m', $ts ?: time());
}
function policyAttachmentPath(string $when, string $stored, bool $forWrite = false): string {
    $bucketed = POLICY_UPLOAD_DIR . policyMonthBucket($when) . '/' . $stored;
    if ($forWrite) return $bucketed;
    if (is_file($bucketed)) return $bucketed;
    $flat = POLICY_UPLOAD_DIR . $stored;
    return is_file($flat) ? $flat : $bucketed;
}

// PDF.js asset URLs — both files must be present.
// Relative path (no leading slash) so it works regardless of whether
// WorkPulse is mounted at the domain root or under a subdirectory
// like /wp/ or /test/.
function policyPdfjsAssetUrl(string $name = 'pdf.mjs'): string {
    return 'lib/pdfjs/' . $name;
}

// ── Audience helpers ────────────────────────────────────
function policyStaffTypesForCategory(string $cat): array {
    return $cat === 'store_management' ? ['retail'] : ['retail','ho','factory'];
}

// Returns an associative array:
//   ['departments' => [int...], 'locations' => [int...]]
// Empty arrays = no filter (everyone in scope of the staff-type passes).
function policyAudienceForVersion(int $versionId): array {
    $depts = [];
    $locs  = [];
    try {
        $st = getDb()->prepare(
            'SELECT department_id, location_id
             FROM   policy_audience
             WHERE  policy_version_id = ?'
        );
        $st->execute([$versionId]);
        foreach ($st->fetchAll(PDO::FETCH_ASSOC) as $r) {
            if ($r['department_id'] !== null) $depts[] = (int)$r['department_id'];
            if ($r['location_id']   !== null) $locs[]  = (int)$r['location_id'];
        }
    } catch (Exception $e) { /* tables may not exist */ }
    return [
        'departments' => array_values(array_unique($depts)),
        'locations'   => array_values(array_unique($locs)),
    ];
}

// Is the current employee in scope for this version?
function policyEmployeeInScope(array $emp, array $version): bool {
    $cat        = $version['category'];
    $staffTypes = policyStaffTypesForCategory($cat);
    if (!in_array($emp['staff_type'] ?? 'retail', $staffTypes, true)) return false;
    $aud = policyAudienceForVersion((int)$version['id']);
    if (!empty($aud['departments'])) {
        if (!in_array((int)($emp['department_id'] ?? 0), $aud['departments'], true)) return false;
    }
    if (!empty($aud['locations'])) {
        if (!in_array((int)($emp['location_id'] ?? 0), $aud['locations'], true)) return false;
    }
    return true;
}

// All currently-active versions visible to one employee, with consent state.
function policyActiveVersionsForEmployee(string $empCode): array {
    try {
        $emp = getDb()->prepare(
            'SELECT department_id, location_id, staff_type FROM employees WHERE employee_code = ? AND is_active = 1'
        );
        $emp->execute([$empCode]);
        $eRow = $emp->fetch(PDO::FETCH_ASSOC);
        if (!$eRow) return [];

        // Latest version per active policy.
        $st = getDb()->query(
            "SELECT v.id, v.policy_id, v.version_label, v.effective_date, v.published_at,
                    v.grace_days, v.what_changed, v.is_major_update,
                    v.pdf_original_name, v.pdf_size_bytes,
                    p.title, p.category, p.is_active AS policy_active
             FROM   policy_versions v
             JOIN   policies p ON p.id = v.policy_id
             WHERE  p.is_active = 1
               AND  v.superseded_at IS NULL
             ORDER  BY v.published_at DESC"
        );
        $rows = $st->fetchAll(PDO::FETCH_ASSOC);

        $consents = getDb()->prepare(
            'SELECT consented_at FROM policy_consents
              WHERE policy_version_id = ? AND employee_code = ? LIMIT 1'
        );

        $out = [];
        foreach ($rows as $v) {
            if (!policyEmployeeInScope($eRow, $v)) continue;
            $consents->execute([$v['id'], $empCode]);
            $c = $consents->fetch(PDO::FETCH_ASSOC);
            $consented = !empty($c);
            $deadline  = strtotime($v['published_at']) + ((int)$v['grace_days'] * 86400);
            // "blocking" = past grace deadline AND unaccepted. Drives the
            // per-request hard-lock gate in index.php. Within grace, the
            // user can navigate freely (soft nudge happens once at login).
            $blocking  = !$consented && time() > $deadline;
            $v['consented']    = $consented;
            $v['consented_at'] = $c['consented_at'] ?? null;
            $v['deadline']     = date('Y-m-d', $deadline);
            $v['blocking']     = $blocking;
            $out[] = $v;
        }
        return $out;
    } catch (Exception $e) { return []; }
}

// Returns the FIRST blocking version for the current user, or null
// if everything is consented or still inside grace. Used by the
// whole-app blocking gate (Phase 5 step 4 — added to auth.php).
function policyFirstBlockingVersion(string $empCode): ?array {
    foreach (policyActiveVersionsForEmployee($empCode) as $v) {
        if (!empty($v['blocking'])) return $v;
    }
    return null;
}

// First unaccepted in-scope policy regardless of grace period. Used as a
// one-time soft nudge right after login — lands the user on the policy
// page so they see the new policy, but they can navigate away (the
// per-request hard-lock only fires after grace, via the function above).
function policyFirstUnacceptedVersion(string $empCode): ?array {
    foreach (policyActiveVersionsForEmployee($empCode) as $v) {
        if (empty($v['consented'])) return $v;
    }
    return null;
}

// ── Pages ───────────────────────────────────────────────

